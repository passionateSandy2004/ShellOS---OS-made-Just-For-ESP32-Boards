# ESP32-CAM (AI Thinker) — give the full board to ShellOS
# Appended on top of sdkconfig.defaults by idf.py for target esp32.

# ── CPU ───────────────────────────────────────────────────────────────────────
CONFIG_ESP32_DEFAULT_CPU_FREQ_240=y

# ── PSRAM (4 MB external, on all AI Thinker modules) ─────────────────────────
#
#  Strategy: route malloc() to PSRAM so the 4 MB external RAM is fully
#  available to ShellOS (Lua heap, HTTP upload buffers, file content, etc.).
#  Task stacks and other small hot allocations stay in fast internal SRAM
#  so context switches are never delayed by the PSRAM latency penalty.
#
CONFIG_ESP32_SPIRAM_SUPPORT=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_BOOT_INIT=y

# Allocations <= 16 KB go to internal SRAM.
# This covers every task stack we create (shell 16K, netsh 16K, httpd 8K …)
# and all small kernel objects (mutexes, queues, TCBs, sockets).
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384

# Reserve 32 KB of internal heap unconditionally so critical paths never
# fail due to fragmentation even while PSRAM is heavily loaded.
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768

# ── WiFi IRAM optimisations ───────────────────────────────────────────────────
# Run the WiFi driver's hot paths directly from IRAM — cuts interrupt
# latency and improves TCP throughput at 240 MHz.
CONFIG_ESP32_WIFI_IRAM_OPT=y
CONFIG_ESP32_WIFI_RX_IRAM_OPT=y

# ── Camera SCCB ───────────────────────────────────────────────────────────────
CONFIG_SCCB_HARDWARE_I2C_PORT0=y
